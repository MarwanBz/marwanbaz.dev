{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "date": {
      "type": "date",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "coverImage": {
      "type": "text"
    },
    "bodyMdx": {
      "type": "text",
      "required": true
    },
    "tags": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    }
  }
}
